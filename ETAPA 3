def criar_mapeamento_meses():
    """Cria dicionário para converter mês texto para número e vice-versa."""
    mes_texto_para_numero = {
        'jan': 1, 'fev': 2, 'mar': 3, 'abr': 4, 'mai': 5, 'jun': 6,
        'jul': 7, 'ago': 8, 'set': 9, 'out': 10, 'nov': 11, 'dez': 12
    }
    mes_numero_para_texto = {v: k for k, v in mes_texto_para_numero.items()}
    return mes_texto_para_numero, mes_numero_para_texto


def aplicar_de_para(df, caminho_de_para):
    """
    Aplica o mapeamento DE→PARA nos códigos e nomes de produto.
    Substitui codigo_produto e nome produto antigos pelos novos conforme FONTE_DE_PARA.
    """
    print("\n    [1.1] Aplicando mapeamento DE→PARA no histórico...")

    try:
        df_de_para = pd.read_excel(caminho_de_para)
        df_de_para.columns = df_de_para.columns.str.strip()
    except FileNotFoundError:
        print("      ⚠ Arquivo FONTE_DE_PARA não encontrado. Seguindo sem substituição.")
        return df
    except Exception as e:
        print(f"      ⚠ Erro ao ler FONTE_DE_PARA: {e}. Seguindo sem substituição.")
        return df

    if df_de_para.empty:
        print("      ⚠ Tabela DE→PARA vazia. Seguindo sem substituição.")
        return df

    df['codigo_produto'] = df['codigo_produto'].astype(str).str.strip()
    df_de_para['codigo_produto_DE'] = df_de_para['codigo_produto_DE'].astype(str).str.strip()
    df_de_para['codigo_produto_PARA'] = df_de_para['codigo_produto_PARA'].astype(str).str.strip()

    mapa_codigo = dict(zip(df_de_para['codigo_produto_DE'], df_de_para['codigo_produto_PARA']))
    mapa_nome = dict(zip(df_de_para['codigo_produto_DE'], df_de_para['nome_produto_PARA']))

    mascara = df['codigo_produto'].isin(mapa_codigo.keys())
    qtd_afetados = mascara.sum()

    df.loc[mascara, 'nome produto'] = df.loc[mascara, 'codigo_produto'].map(mapa_nome)
    df.loc[mascara, 'codigo_produto'] = df.loc[mascara, 'codigo_produto'].map(mapa_codigo)

    print(f"      ✓ Mapeamentos carregados: {len(mapa_codigo)}")
    print(f"      ✓ Registros substituídos: {qtd_afetados:,}")

    return df


