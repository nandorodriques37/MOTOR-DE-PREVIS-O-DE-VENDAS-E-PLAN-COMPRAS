def carregar_e_aplicar_ajuste_comercial(df_final):
    """
    Carrega o arquivo ETAPA_5_INPUT_COMERCIAL.xlsx e aplica os ajustes
    percentuais nos meses m1, m2, m3 do forecast.

    Lógica:
    - m0 (primeiro mês de forecast): NÃO recebe ajuste (congelado)
    - m1, m2, m3: Previsao_Ajustada = Previsao_Vendas × (1 + Ajuste%)
    - m4 em diante: Previsao_Ajustada = Previsao_Vendas (sem ajuste)
    - Histórico: Previsao_Ajustada permanece NaN
    - SKUs sem match no input comercial: Previsao_Ajustada = Previsao_Vendas

    O match é feito por: Fornecedor + Cat Nivel 3 + Cat Nivel 4
    """
    print("\n[10.5] Aplicando ajustes comerciais (ETAPA 5)...")

    # -------------------------------------------------------------------------
    # 1. Carregar arquivo de input comercial
    # -------------------------------------------------------------------------
    try:
        df_input = pd.read_excel(PATH_INPUT_COMERCIAL)
        df_input.columns = df_input.columns.str.strip()
    except FileNotFoundError:
        print("      ⚠ Arquivo ETAPA_5_INPUT_COMERCIAL não encontrado.")
        print("      → Previsao_Ajustada será igual à Previsao_Vendas.")
        df_final['Previsao_Ajustada'] = df_final['Previsao_Vendas']
        return df_final
    except Exception as e:
        print(f"      ⚠ Erro ao ler input comercial: {e}")
        df_final['Previsao_Ajustada'] = df_final['Previsao_Vendas']
        return df_final

    print(f"    - Input comercial: {df_input.shape[0]} linhas carregadas")

    # -------------------------------------------------------------------------
    # 2. Identificar meses m0, m1, m2, m3 do forecast
    # -------------------------------------------------------------------------
    df_fc = df_final[df_final['tipo'] == 'forecast'].copy()

    if df_fc.empty:
        print("      ⚠ Sem dados de forecast. Nenhum ajuste aplicado.")
        df_final['Previsao_Ajustada'] = df_final['Previsao_Vendas']
        return df_final

    meses_forecast = sorted(df_fc['ano_mes'].unique())
    print(f"    - Meses de forecast encontrados: {meses_forecast[:6]}{'...' if len(meses_forecast) > 6 else ''}")

    # Mapear m0, m1, m2, m3 para os respectivos ano_mes
    mapa_mes_ajuste = {}
    if len(meses_forecast) >= 2:
        mapa_mes_ajuste[meses_forecast[1]] = 'Ajuste % (mês 1)'
    if len(meses_forecast) >= 3:
        mapa_mes_ajuste[meses_forecast[2]] = 'Ajuste % (mês 2)'
    if len(meses_forecast) >= 4:
        mapa_mes_ajuste[meses_forecast[3]] = 'Ajuste % (mês 3)'

    print(f"    - Mapeamento de ajustes:")
    print(f"      m0 = {meses_forecast[0]} → SEM AJUSTE (congelado)")
    for ano_mes, col_ajuste in mapa_mes_ajuste.items():
        print(f"      {col_ajuste.replace('Ajuste % (', '').replace(')', '')} = {ano_mes} → {col_ajuste}")
    if len(meses_forecast) > 4:
        print(f"      m4+ = {meses_forecast[4]}... → SEM AJUSTE (mantém original)")

    # -------------------------------------------------------------------------
    # 3. Preparar lookup de ajustes (chave: Fornecedor + Cat3 + Cat4)
    # -------------------------------------------------------------------------
    colunas_ajuste = ['Fornecedor', 'Cat Nivel 3', 'Cat Nivel 4',
                      'Ajuste % (mês 1)', 'Ajuste % (mês 2)', 'Ajuste % (mês 3)']

    colunas_presentes = [c for c in colunas_ajuste if c in df_input.columns]
    if len(colunas_presentes) < 4:  # Pelo menos chave + 1 coluna de ajuste
        print("      ⚠ Colunas de ajuste não encontradas no input comercial.")
        df_final['Previsao_Ajustada'] = df_final['Previsao_Vendas']
        return df_final

    df_ajustes = df_input[colunas_presentes].copy()

    # Preencher NaN com 0 (sem ajuste)
    for col in ['Ajuste % (mês 1)', 'Ajuste % (mês 2)', 'Ajuste % (mês 3)']:
        if col in df_ajustes.columns:
            df_ajustes[col] = pd.to_numeric(df_ajustes[col], errors='coerce').fillna(0)

    # Padronizar strings para o match
    df_ajustes['Fornecedor'] = df_ajustes['Fornecedor'].astype(str).str.strip().str.upper()
    df_ajustes['Cat Nivel 3'] = df_ajustes['Cat Nivel 3'].astype(str).str.strip().str.upper()
    df_ajustes['Cat Nivel 4'] = df_ajustes['Cat Nivel 4'].astype(str).str.strip().str.upper()

    # -------------------------------------------------------------------------
    # 4. Aplicar ajustes linha a linha no forecast
    # -------------------------------------------------------------------------
    # Criar colunas auxiliares padronizadas no df_final para match
    df_final['_forn_upper'] = df_final['fornecedor comercial'].astype(str).str.strip().str.upper()
    df_final['_cat3_upper'] = df_final['nome nível 3'].astype(str).str.strip().str.upper()
    df_final['_cat4_upper'] = df_final['nome nível 4'].astype(str).str.strip().str.upper()

    # Criar dicionário de ajustes indexado pela chave composta
    dict_ajustes = {}
    for _, row in df_ajustes.iterrows():
        chave = (row['Fornecedor'], row['Cat Nivel 3'], row['Cat Nivel 4'])
        dict_ajustes[chave] = {
            'Ajuste % (mês 1)': row.get('Ajuste % (mês 1)', 0),
            'Ajuste % (mês 2)': row.get('Ajuste % (mês 2)', 0),
            'Ajuste % (mês 3)': row.get('Ajuste % (mês 3)', 0),
        }

    print(f"    - Chaves de ajuste carregadas: {len(dict_ajustes)}")

    # Inicializar Previsao_Ajustada = Previsao_Vendas (default para tudo)
    df_final['Previsao_Ajustada'] = df_final['Previsao_Vendas'].copy()

    # Aplicar ajuste apenas nas linhas de forecast com match
    contador_ajustados = 0
    contador_sem_match = 0

    for idx in df_final[df_final['tipo'] == 'forecast'].index:
        ano_mes = df_final.at[idx, 'ano_mes']

        # Verificar se este mês tem ajuste definido
        if ano_mes not in mapa_mes_ajuste:
            continue  # m0 ou m4+ → sem ajuste

        col_ajuste = mapa_mes_ajuste[ano_mes]
        chave = (
            df_final.at[idx, '_forn_upper'],
            df_final.at[idx, '_cat3_upper'],
            df_final.at[idx, '_cat4_upper']
        )

        if chave in dict_ajustes:
            pct_ajuste = dict_ajustes[chave].get(col_ajuste, 0)
            if pct_ajuste != 0:
                valor_original = df_final.at[idx, 'Previsao_Vendas']
                if pd.notna(valor_original):
                    df_final.at[idx, 'Previsao_Ajustada'] = round(valor_original * (1 + pct_ajuste))
                    contador_ajustados += 1
        else:
            contador_sem_match += 1

    # Limpar colunas auxiliares
    df_final = df_final.drop(columns=['_forn_upper', '_cat3_upper', '_cat4_upper'])

    # -------------------------------------------------------------------------
    # 5. Relatório do ajuste
    # -------------------------------------------------------------------------
    total_forecast = (df_final['tipo'] == 'forecast').sum()
    total_com_ajuste_potencial = sum(1 for m in meses_forecast[1:4] if m in mapa_mes_ajuste)

    print(f"\n    ✓ RESUMO DO AJUSTE COMERCIAL:")
    print(f"      - Total de linhas forecast: {total_forecast:,}")
    print(f"      - Linhas efetivamente ajustadas (% ≠ 0): {contador_ajustados:,}")
    print(f"      - Linhas sem match no input comercial: {contador_sem_match:,}")

    # Mostrar resumo dos ajustes por chave
    if dict_ajustes:
        print(f"\n    📋 Ajustes configurados:")
        for chave, vals in dict_ajustes.items():
            ajustes_str = " | ".join([
                f"{k.replace('Ajuste % (', '').replace(')', '')}: {v:+.1%}"
                for k, v in vals.items()
            ])
            print(f"      {chave[0]} / {chave[1]} / {chave[2]} → {ajustes_str}")

    return df_final


# =============================================================================
# FUNÇÃO PARA GERAR ABA DE ANÁLISE POR CATEGORIA NÍVEL 4
# =============================================================================

def criar_aba_analise_categoria(df_final):
    """
    Cria análise por Categoria Nível 3 e Nível 4 com:
    - Previsão dos próximos 4 meses (m0, m1, m2, m3)
    - Variação vs ano anterior (LY) e mês anterior (LM)
    - Comparativo de trimestres (apenas m0, m1 e m2)
    - >>> NOVO: Usa Previsao_Ajustada no forecast
    """
    print("\n[11] Criando aba de análise por Categoria Nível 4...")

    df_hist = df_final[df_final['tipo'] == 'Historico'].copy()
    df_fc = df_final[df_final['tipo'] == 'forecast'].copy()

    if df_fc.empty:
        print("    ⚠️ Sem dados de forecast para análise")
        return pd.DataFrame()

    meses_forecast = sorted(df_fc['ano_mes'].unique())

    if len(meses_forecast) < 4:
        print("    ⚠️ Forecast insuficiente (precisa de pelo menos 4 meses)")
        return pd.DataFrame()

    m0 = meses_forecast[0]
    m1 = meses_forecast[1]
    m2 = meses_forecast[2]
    m3 = meses_forecast[3]

    def get_mes_ly(ano_mes):
        ano, mes = ano_mes.split('_')
        return f"{int(ano) - 1}_{mes}"

    def get_mes_anterior(ano_mes):
        ano, mes = int(ano_mes.split('_')[0]), int(ano_mes.split('_')[1])
        if mes == 1:
            return f"{ano - 1}_12"
        else:
            return f"{ano}_{str(mes - 1).zfill(2)}"

    m0_ly = get_mes_ly(m0)
    m1_ly = get_mes_ly(m1)
    m2_ly = get_mes_ly(m2)
    m3_ly = get_mes_ly(m3)
    m0_lm = get_mes_anterior(m0)

    # >>> MODIFICADO: Usar Previsao_Ajustada ao invés de Previsao_Vendas
    vendas_hist = df_hist.groupby(['nome nível 3', 'nome nível 4', 'ano_mes'])['Qtd Bruta'].sum().reset_index()
    vendas_hist_pivot = vendas_hist.pivot(index=['nome nível 3', 'nome nível 4'], columns='ano_mes', values='Qtd Bruta').fillna(0)

    vendas_fc = df_fc.groupby(['nome nível 3', 'nome nível 4', 'ano_mes'])['Previsao_Ajustada'].sum().reset_index()
    vendas_fc_pivot = vendas_fc.pivot(index=['nome nível 3', 'nome nível 4'], columns='ano_mes', values='Previsao_Ajustada').fillna(0)

    meses_hist = sorted(df_hist['ano_mes'].unique(), reverse=True)
    ultimo_tri_meses = meses_hist[0:3] if len(meses_hist) >= 3 else []

    categorias = df_final[['nome nível 3', 'nome nível 4']].drop_duplicates().dropna()
    resultado = []

    for _, cat_row in categorias.iterrows():
        cat3 = cat_row['nome nível 3']
        cat4 = cat_row['nome nível 4']

        row = {'Cat Nivel 3': cat3, 'Cat Nivel 4': cat4}

        def get_hist(mes):
            if mes in vendas_hist_pivot.columns and (cat3, cat4) in vendas_hist_pivot.index:
                return vendas_hist_pivot.loc[(cat3, cat4), mes]
            return 0

        def get_fc(mes):
            if mes in vendas_fc_pivot.columns and (cat3, cat4) in vendas_fc_pivot.index:
                return vendas_fc_pivot.loc[(cat3, cat4), mes]
            return 0

        val_m0 = get_fc(m0)
        val_m1 = get_fc(m1)
        val_m2 = get_fc(m2)
        val_m3 = get_fc(m3)

        val_m0_ly = get_hist(m0_ly)
        val_m1_ly = get_hist(m1_ly)
        val_m2_ly = get_hist(m2_ly)
        val_m3_ly = get_hist(m3_ly)
        val_m0_lm = get_hist(m0_lm)

        # Mês 0
        row['mês 0'] = val_m0
        row['% Var LY'] = ((val_m0 / val_m0_ly) - 1) if val_m0_ly > 0 else None
        row['% Var LM'] = ((val_m0 / val_m0_lm) - 1) if val_m0_lm > 0 else None

        # Mês 1
        row['mês 1'] = val_m1
        row['% Var LY_1'] = ((val_m1 / val_m1_ly) - 1) if val_m1_ly > 0 else None
        row['% Var LM_1'] = ((val_m1 / val_m0) - 1) if val_m0 > 0 else None

        # Mês 2
        row['mês 2'] = val_m2
        row['% Var LY_2'] = ((val_m2 / val_m2_ly) - 1) if val_m2_ly > 0 else None
        row['% Var LM_2'] = ((val_m2 / val_m1) - 1) if val_m1 > 0 else None

        # Mês 3
        row['mês 3'] = val_m3
        row['% Var LY_3'] = ((val_m3 / val_m3_ly) - 1) if val_m3_ly > 0 else None
        row['% Var LM_3'] = ((val_m3 / val_m2) - 1) if val_m2 > 0 else None

        # Trimestres (m0 + m1 + m2)
        tri_atual = val_m0 + val_m1 + val_m2
        tri_ly = val_m0_ly + val_m1_ly + val_m2_ly
        tri_ultimo = sum([get_hist(m) for m in ultimo_tri_meses]) if ultimo_tri_meses else 0

        row['Trimestre ano anterior'] = tri_ly
        row['Ultimo Trimestre'] = tri_ultimo
        row['Trimestre atual (m0/m1/m2)'] = tri_atual
        row['% var TRI atual vs LY'] = ((tri_atual / tri_ly) - 1) if tri_ly > 0 else None
        row['% var TRI atual vs ultimo TRI'] = ((tri_atual / tri_ultimo) - 1) if tri_ultimo > 0 else None
        row['Comentarios'] = ''

        resultado.append(row)

    df_analise = pd.DataFrame(resultado)
    df_analise = df_analise.sort_values(['Cat Nivel 3', 'Trimestre atual (m0/m1/m2)'], ascending=[True, False])

    print(f"    ✓ Análise criada: {len(df_analise)} categorias")

    return df_analise


def salvar_resultado_com_analise(df_final, df_analise, path_output):
    """Salva o resultado em arquivo Excel com duas abas e formatação."""
    print(f"\n[12] Salvando arquivo com 2 abas...")

    from openpyxl.styles import Font, PatternFill, Alignment, Border, Side
    from openpyxl.utils import get_column_letter

    with pd.ExcelWriter(path_output, engine='openpyxl') as writer:
        df_final.to_excel(writer, sheet_name='Previsao_SKU', index=False)

        if not df_analise.empty:
            df_analise.to_excel(writer, sheet_name='Analise_Categoria', index=False)

            workbook = writer.book
            ws = writer.sheets['Analise_Categoria']

            amarelo = PatternFill(start_color='FFFF99', end_color='FFFF99', fill_type='solid')
            verde = PatternFill(start_color='C6EFCE', end_color='C6EFCE', fill_type='solid')
            azul = PatternFill(start_color='BDD7EE', end_color='BDD7EE', fill_type='solid')
            header_fill = PatternFill(start_color='D9D9D9', end_color='D9D9D9', fill_type='solid')
            header_font = Font(bold=True)

            colunas_amarelo = ['mês 0', 'mês 1', 'mês 2', 'mês 3', 'Trimestre ano anterior', 'Ultimo Trimestre', 'Trimestre atual (m0/m1/m2)']
            colunas_verde = ['% Var LM', '% Var LM_1', '% Var LM_2', '% Var LM_3']
            colunas_azul = ['% var TRI atual vs LY', '% var TRI atual vs ultimo TRI']
            colunas_percentual = ['% Var LY', '% Var LM', '% Var LY_1', '% Var LM_1', '% Var LY_2', '% Var LM_2', '% Var LY_3', '% Var LM_3', '% var TRI atual vs LY', '% var TRI atual vs ultimo TRI']
            colunas_numero = ['mês 0', 'mês 1', 'mês 2', 'mês 3', 'Trimestre ano anterior', 'Ultimo Trimestre', 'Trimestre atual (m0/m1/m2)']

            for col_idx in range(1, len(df_analise.columns) + 1):
                cell = ws.cell(row=1, column=col_idx)
                cell.fill = header_fill
                cell.font = header_font
                cell.alignment = Alignment(horizontal='center', wrap_text=True)

            for col_idx, col_name in enumerate(df_analise.columns, 1):
                col_letter = get_column_letter(col_idx)

                if col_name == 'Cat Nivel 4':
                    ws.column_dimensions[col_letter].width = 22
                elif col_name == 'Comentarios':
                    ws.column_dimensions[col_letter].width = 15
                elif '%' in col_name:
                    ws.column_dimensions[col_letter].width = 12
                else:
                    ws.column_dimensions[col_letter].width = 14

                for row_idx in range(2, len(df_analise) + 2):
                    cell = ws.cell(row=row_idx, column=col_idx)

                    if col_name in colunas_amarelo:
                        cell.fill = amarelo
                    elif col_name in colunas_verde:
                        cell.fill = verde
                    elif col_name in colunas_azul:
                        cell.fill = azul

                    if col_name in colunas_numero:
                        cell.number_format = '#,##0'
                    if col_name in colunas_percentual:
                        cell.number_format = '0.0%'

                    if col_name != 'Cat Nivel 4' and col_name != 'Comentarios':
                        cell.alignment = Alignment(horizontal='center')

            ws.freeze_panes = 'B2'

    print(f"    ✓ Arquivo salvo: {path_output}")
    print(f"    ✓ Aba 1: Previsao_SKU (com Previsao_Ajustada)")
    print(f"    ✓ Aba 2: Analise_Categoria (usando valores ajustados)")


